@model List<AppUser>
@{
    ViewData["Title"] = "UserList";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1>List of Users</h1>

<table class="table table-bordered">
    <tr>
        <th>Name</th>
        <th>Assign a Role</th>
    </tr>
    @foreach(var item in Model)
    {
        <tr>
            <td>@item.UserName</td>
            <td><a href="/Admin/Role/AssignRole/@item.Id" class="btn btn-warning">Assign</a></td>
        </tr>
    }
</table>

