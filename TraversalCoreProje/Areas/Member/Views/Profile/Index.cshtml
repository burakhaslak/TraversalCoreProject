@model TraversalCoreProje.Areas.Member.Models.UserEditViewModel
@{
    ViewData["Title"] = "Index";
	Layout = "~/Views/Shared/_MemberLayout.cshtml";
}


<div class="row">
	<div class="col-12">
		<div class="card">
			<div class="card-header">
				<h4 class="card-title">Profile Editing</h4>
				<a class="heading-elements-toggle"><i class="la la-ellipsis-v font-medium-3"></i></a>
				<div class="heading-elements">
					<ul class="list-inline mb-0">
						<li><a data-action="collapse"><i class="ft-minus"></i></a></li>
						<li><a data-action="reload"><i class="ft-rotate-cw"></i></a></li>
						<li><a data-action="expand"><i class="ft-maximize"></i></a></li>
						<li><a data-action="close"><i class="ft-x"></i></a></li>
					</ul>
				</div>
			</div>
			<div class="card-content collapse show">
				<div class="card-body">
					<p class="card-text">You can access and edit your profile with ease.</p>
                    <form method="post" enctype="multipart/form-data">
                        @Html.Label("Your Name")
                        <input type="text" asp-for="name" class="form-control" />
                        <br />
                        @Html.Label("Your Surname")
                        <input type="text" asp-for="surname" class="form-control" />
                        <br />
                        @Html.Label("Your Mail")
                        <input type="text" asp-for="mail" class="form-control" />
                        <br />
                        @Html.Label("Your Password")
                        <input type="text" asp-for="password" class="form-control" />
                        <br />
                        @Html.Label("Your Password Again")
                        <input type="text" asp-for="confirmpassword" class="form-control" />
                        <br />
                        @Html.Label("Your Mobile")
                        <input type="text" asp-for="mobile" class="form-control" />
                        <br />
                        <div class="form-group">
                            <label>Choose an image</label>
                            <input type="file" asp-for="Image" />
                        </div>
                        <br />
                        <button class="btn btn-outline-primary">Update Profile</button>
                    </form>
				</div>
			</div>
		</div>
	</div>
</div>


