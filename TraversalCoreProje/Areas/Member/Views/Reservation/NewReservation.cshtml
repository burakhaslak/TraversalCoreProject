@model EntityLayer.Concrete.Reservation
@{
	ViewData["Title"] = "NewReservation";
	Layout = "~/Views/Shared/_MemberLayout.cshtml";
}


<div class="row">
	<div class="col-12">
		<div class="card">
			<div class="card-header">
				<h4 class="card-title">New Reservations</h4>
				<a class="heading-elements-toggle"><i class="la la-ellipsis-v font-medium-3"></i></a>
				<div class="heading-elements">
					<ul class="list-inline mb-0">
						<li><a data-action="collapse"><i class="ft-minus"></i></a></li>
						<li><a data-action="reload"><i class="ft-rotate-cw"></i></a></li>
						<li><a data-action="expand"><i class="ft-maximize"></i></a></li>
						<li><a data-action="close"><i class="ft-x"></i></a></li>
					</ul>
				</div>
			</div>
			<div class="card-content collapse show">
				<div class="card-body">
					<p class="card-text">You can access and create new reservations with ease.</p>
					<form method="post">
						<div class="form-group">
							@Html.Label("Number of Participants")
							<input type="text" asp-for="PersonCount" class="form-control" />
						</div>
						<div class="form-group">
							@Html.Label("Date")
							<input type="date" asp-for="ReservationDate" class="form-control" />
						</div>
						<div class="form-group">
							@Html.Label("Additional Comments")
							<input type="text" asp-for="Description" class="form-control" />
						</div>
						<button class="btn btn-outline-success">Make a Resevation</button>
					</form>
				</div>
			</div>
		</div>
	</div>
</div>



