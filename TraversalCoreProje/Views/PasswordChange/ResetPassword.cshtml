@model ResetPasswordViewModel
@{
    Layout = null;
}

<a href="~/lib/bootstrap/dist/css/bootstrap.min.css.map">~/lib/bootstrap/dist/css/bootstrap.min.css.map</a>
<link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
<div class="container">
    <br /><br />
    <h2>Reset Your Password</h2>
    <form method="post">
        <label>Password</label>
        <input type="text" class="form-control" asp-for="Password" />
        <br />
        <label>Confirm Password</label>
        <input type="text" class="form-control" asp-for="ConfirmPassword" />
        <br />
        <button class="btn btn-primary">Reset Password</button>
    </form>
</div>
